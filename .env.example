"""Environment configuration template for secure deployment.

Copy to .env and fill with actual values. NEVER commit .env to git!
"""

# ============================================================
# 🔐 CRITICAL: Keep this file secure and never commit to git
# ============================================================

# Database Configuration
# Use strong password (32+ chars, mixed case, numbers, symbols)
DB_PASSWORD=ChangeMeToStrongPassword32CharsMin!
DB_HOST=postgres
DB_PORT=5432
DB_NAME=nemoclaw_prod
DB_USER=nemoclaw_app
DB_SSL_MODE=require

# Session & Authentication
# Generate with: openssl rand -base64 64
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# OAuth2 / SSO Configuration (if using)
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=https://your-domain.com/auth/callback
OAUTH_SCOPE=openid email profile

# SAML Configuration (if using)
SAML_ENTITY_ID=https://your-domain.com/metadata
SAML_IDP_METADATA_URL=https://idp-provider.com/metadata
SAML_CERT_PATH=/secrets/saml.crt
SAML_KEY_PATH=/secrets/saml.key

# Encryption Keys
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
AUDIT_SIGNING_KEY=REPLACE_WITH_DIFFERENT_64_HEX_CHARS

# OpenShell / NemoClaw Connection
OPENSHLL_API_KEY=REPLACE_WITH_SECURE_API_KEY
OPENSHLL_API_URL=https://openshell-api.internal:8443
OPENSHLL_VERIFY_SSL=true
OPENSHLL_CA_CERT_PATH=/secrets/ca.crt

# External API Keys (rotate monthly)
VIRUSTOTAL_API_KEY=your-vt-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-key
THREAT_INTEL_API_KEY=your-threat-intel-key

# Redis Cache (if using)
REDIS_PASSWORD=ChangeMeToStrongRedisPass!
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_SSL=true

# Email / SMTP (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_TLS=true
SMTP_FROM=noreply@your-domain.com

# TLS/SSL Configuration
TLS_CERT_PATH=/secrets/tls.crt
TLS_KEY_PATH=/secrets/tls.key
TLS_CA_PATH=/secrets/ca-bundle.crt
TLS_MIN_VERSION=1.3
HSTS_MAX_AGE=31536000

# Feature Flags
ENABLE_MFA=true
ENABLE_SSO=true
ENABLE_AUDIT_LOGGING=true
ENABLE_IP_WHITELIST=false
MAINTENANCE_MODE=false

# IP Restrictions (comma-separated)
# ADMIN_IP_WHITELIST=10.0.0.0/8,192.168.1.0/24

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_WINDOW=300
RATE_LIMIT_API=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_PATH=/app/logs/audit.log
APP_LOG_PATH=/app/logs/app.log

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_S3_BUCKET=nemoclaw-backups-prod
BACKUP_S3_REGION=us-east-1

# Monitoring
SENTRY_DSN=https://your-sentry-dsn
DATADOG_API_KEY=your-datadog-key
PROMETHEUS_ENABLED=true
HEALTH_CHECK_TOKEN=REPLACE_WITH_RANDOM_TOKEN

# Development/Testing ONLY - Set to false in production
DEBUG=false
DEV_MODE=false
MOCK_SERVICES=false

# ============================================================
# 📝 Deployment Checklist:
# [ ] All passwords changed from defaults
# [ ] Secret keys generated with cryptographically secure method
# [ ] SSL certificates installed and valid
# [ ] File permissions set (600 for keys, 644 for certs)
# [ ] Database encrypted at rest
# [ ] Network segmentation configured
# [ ] Backup and recovery tested
# [ ] Audit logging enabled
# [ ] Rate limiting configured
# [ ] MFA enforced for admin accounts
# ============================================================
